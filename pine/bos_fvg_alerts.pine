//@version=5
indicator("BOS + FVG Alert Generator", overlay=true)

// --- Inputs ---
length = input.int(5, "Swing Length")
atr_length = input.int(14, "ATR Length")
disp_mult = input.float(1.5, "Displacement ATR Multiplier")
session_str = input.session("0930-1600", "Active Session (EST)")
htf_bias_input = input.string("BULLISH", "HTF Bias", options=["BULLISH", "BEARISH", "NEUTRAL"])
risk_reward = input.float(2.0, "Target R:R")

// --- Session Filter ---
inSession = not na(time(timeframe.period, session_str, "America/New_York"))
session_name = inSession ? "NY" : "NONE"

// --- Swing Points (Basic) ---
var float swingHigh = na
var float swingLow = na
if ta.highest(high, length * 2 + 1) == high[length]
    swingHigh := high[length]
if ta.lowest(low, length * 2 + 1) == low[length]
    swingLow := low[length]

// --- BOS Logic ---
bullBOS = close > swingHigh and close[1] <= swingHigh
bearBOS = close < swingLow and close[1] >= swingLow

// --- FVG Logic ---
bullFVG = low > high[2] and close > open
bearFVG = high < low[2] and close < open

// --- Displacement ---
atr = ta.atr(atr_length)
bodySize = math.abs(close - open)
displacement_mult = bodySize / atr

// --- Setup Conditions ---
long_setup = bullBOS and bullFVG and inSession
short_setup = bearBOS and bearFVG and inSession

// --- Alert Values ---
float entry_price = close
float stop_price = long_setup ? low[1] : (short_setup ? high[1] : na)
float target_price = long_setup ? entry_price + (entry_price - stop_price) * risk_reward : (short_setup ? entry_price - (stop_price - entry_price) * risk_reward : na)

// --- JSON Strings ---
webhook_json_long = '{"symbol": "' + syminfo.ticker + '", "timeframe": "' + timeframe.period + '", "direction": "LONG", "entry": ' + str.tostring(entry_price) + ', "stop": ' + str.tostring(stop_price) + ', "target": ' + str.tostring(target_price) + ', "bos_detected": true, "fvg_detected": true, "displacement_atr_mult": ' + str.tostring(displacement_mult) + ', "active_session": "' + session_name + '", "htf_bias": "' + htf_bias_input + '"}'

webhook_json_short = '{"symbol": "' + syminfo.ticker + '", "timeframe": "' + timeframe.period + '", "direction": "SHORT", "entry": ' + str.tostring(entry_price) + ', "stop": ' + str.tostring(stop_price) + ', "target": ' + str.tostring(target_price) + ', "bos_detected": true, "fvg_detected": true, "displacement_atr_mult": ' + str.tostring(displacement_mult) + ', "active_session": "' + session_name + '", "htf_bias": "' + htf_bias_input + '"}'

// --- Fires ---
if long_setup
    alert(webhook_json_long, alert.freq_once_per_bar_close)
if short_setup
    alert(webhook_json_short, alert.freq_once_per_bar_close)

plotshape(long_setup, style=shape.triangleup, location=location.belowbar, color=color.green, size=size.small, title="Long Setup")
plotshape(short_setup, style=shape.triangledown, location=location.abovebar, color=color.red, size=size.small, title="Short Setup")
