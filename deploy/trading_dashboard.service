[Unit]
Description=Trading Bot Streamlit UI Dashboard
After=network.target

[Service]
Type=simple
User={{USER}}
WorkingDirectory={{APP_DIR}}
ExecStart={{APP_DIR}}/venv/bin/python -m streamlit run trading_bot_ui.py --server.port 8501 --server.address 127.0.0.1 --server.headless true
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
